Algoritmo sin_titulo
	DEFINIR num1 ,num2, resta, suma, mult, div como real
	escribir ingresa un numero
	leer num1
	escribir ingresa segundo numero
	leer num2
	resta <- num1 - num2
	suma <- num1 + num2
	mult <- num1 * num2 
	div <- num1 / num2
	escribir resta 
	escribir suma
	escribir mult
	escribir div
FinAlgoritmo
